# PaceKeeper — ESPHome secrets (template)
#
# Copy this file to `secrets.yaml` and fill in your real values:
#   cp secrets.yaml.example secrets.yaml
#
# The real `secrets.yaml` is gitignored so your credentials stay local.
# esp-pacekeeper.yaml references these via `!secret <key>`.

# WiFi the ESP32 joins
wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"

# Fallback access point (shown when WiFi is unavailable)
ap_password: "YOUR_AP_PASSWORD"

# Bluetooth address of your treadmill (find via nRF Connect, device "PitPat-T01")
treadmill_mac: "AA:BB:CC:DD:EE:FF"
